programa {
  funcao inicio() {
  //informações
  real nota_A, nota_B, mediaNotas
  //entrada
  escreva("Digite a nota A: ")
  leia(nota_A)
  escreva("Digite a nota B: ")
  leia(nota_B)
  //processamento
  mediaNotas = (nota_A * 3.5 + nota_B * 7.5) / 11
  //saída
  escreva("A sua média é de: " + mediaNotas)

  }
}
